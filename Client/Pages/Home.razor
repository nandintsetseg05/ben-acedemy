@page "/"
@implements IDisposable
@inject UiCultureService Ui

<PageTitle>Ben Academy</PageTitle>

<section class="hero py-5 bg-primary text-white">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold mb-3">@Ui.T("hero_title")</h1>
                <p class="lead mb-4">@Ui.T("hero_sub")</p>
                <a class="btn btn-light btn-lg me-2" href="/register">@Ui.T("cta_signup")</a>
                <a class="btn btn-outline-light btn-lg" href="/login">@Ui.T("cta_login")</a>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h3>AI band estimates</h3>
                <p class="text-muted">Model-driven feedback aligned with IELTS Writing task expectations.</p>
            </div>
            <div class="col-md-4">
                <h3>Track progress</h3>
                <p class="text-muted">Profiles store current and target bands as you improve.</p>
            </div>
            <div class="col-md-4">
                <h3>English / Монгол</h3>
                <p class="text-muted">Switch UI language anytime from the header.</p>
            </div>
        </div>
    </div>
</section>

@code {
    protected override void OnInitialized() => Ui.OnChange += StateHasChanged;
    public void Dispose() => Ui.OnChange -= StateHasChanged;
}
