@page "/ben"
@attribute [Authorize(Roles = AppRoles.Student)]
@implements IDisposable
@inject IHttpClientFactory HttpFactory
@inject AuthenticationStateProvider AuthState
@inject UiCultureService Ui

<PageTitle>Ben AI</PageTitle>

<div class="container py-4" style="max-width: 720px;">
    <h1 class="h3 mb-3">Ben AI – Writing</h1>
    <p class="text-muted">@Ui.T("essay") · Student access only</p>

    <div class="mb-3">
        <label class="form-label">Current band</label>
        <input type="number" step="0.5" min="0" max="9" class="form-control" @bind="_current" />
    </div>
    <div class="mb-3">
        <label class="form-label">Target band</label>
        <input type="number" step="0.5" min="0" max="9" class="form-control" @bind="_target" />
    </div>
    <div class="mb-3">
        <label class="form-label">@Ui.T("essay")</label>
        <textarea class="form-control" rows="12" @bind="_essay"></textarea>
    </div>
    <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">@Ui.T("grade")</button>

    @if (_busy)
    {
        <p class="mt-3 text-muted">@Ui.T("loading")</p>
    }
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
    @if (_result is not null)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h2 class="h5">Band: @_result.BandScore</h2>
                <pre class="small bg-light p-3 rounded mt-2 mb-0" style="white-space: pre-wrap;">@_feedbackPretty</pre>
                @if (_result.SuggestedTasks is { Count: > 0 })
                {
                    <h3 class="h6 mt-3">Suggested tasks</h3>
                    <ul>
                        @foreach (var t in _result.SuggestedTasks!)
                        {
                            <li>@t</li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@code {
    private string _essay = "";
    private float _current = 5f;
    private float _target = 6.5f;
    private bool _busy;
    private string? _error;
    private BenAiResponse? _result;
    private string _feedbackPretty = "";

    protected override void OnInitialized() => Ui.OnChange += StateHasChanged;

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        _result = null;
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            var id = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (id is null || !Guid.TryParse(id, out var userId))
            {
                _error = "Not signed in.";
                return;
            }

            var req = new BenAiRequest
            {
                EssayText = _essay,
                CurrentBand = _current,
                TargetBand = _target,
                UserId = userId
            };

            var client = HttpFactory.CreateClient("Api");
            var res = await client.PostAsJsonAsync("api/ben", req);
            if (res.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                _error = "You can only grade for your own account.";
                return;
            }
            if ((int)res.StatusCode == 429)
            {
                _error = "Too many requests. Try again in a minute.";
                return;
            }
            if (!res.IsSuccessStatusCode)
            {
                _error = await res.Content.ReadAsStringAsync();
                return;
            }

            _result = await res.Content.ReadFromJsonAsync<BenAiResponse>();
            _feedbackPretty = _result?.DetailedFeedback.ValueKind == System.Text.Json.JsonValueKind.Undefined
                ? ""
                : System.Text.Json.JsonSerializer.Serialize(_result!.DetailedFeedback, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose() => Ui.OnChange -= StateHasChanged;
}
