@page "/register"
@implements IDisposable
@inject IHttpClientFactory HttpFactory
@inject JwtAuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject UiCultureService Ui

<PageTitle>@Ui.T("register_title")</PageTitle>

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4">@Ui.T("register_title")</h1>
    <EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />
        <div class="mb-3">
            <label class="form-label">@Ui.T("email")</label>
            <InputText class="form-control" @bind-Value="_model.Email" />
        </div>
        <div class="mb-3">
            <label class="form-label">@Ui.T("password")</label>
            <InputText type="password" class="form-control" @bind-Value="_model.Password" />
        </div>
        <div class="mb-3">
            <label class="form-label">@Ui.T("name")</label>
            <InputText class="form-control" @bind-Value="_model.Name" />
        </div>
        <div class="mb-3">
            <label class="form-label">Language</label>
            <InputSelect class="form-select" @bind-Value="_model.Language">
                <option value="@AppLanguages.English">@Ui.T("lang_en")</option>
                <option value="@AppLanguages.Mongolian">@Ui.T("lang_mn")</option>
            </InputSelect>
        </div>
        <button class="btn btn-primary" type="submit" disabled="@_busy">@Ui.T("submit")</button>
    </EditForm>
    <p class="mt-3"><a href="/login">@Ui.T("cta_login")</a></p>
</div>

@code {
    private readonly RegisterRequest _model = new();
    private bool _busy;

    protected override void OnInitialized() => Ui.OnChange += StateHasChanged;

    private async Task OnSubmitAsync()
    {
        _busy = true;
        try
        {
            var client = HttpFactory.CreateClient("Api");
            var res = await client.PostAsJsonAsync("api/auth/register", _model);
            if (!res.IsSuccessStatusCode)
            {
                _busy = false;
                return;
            }
            var body = await res.Content.ReadFromJsonAsync<LoginResponse>();
            if (body?.Token is { Length: > 0 })
            {
                await Auth.SignInAsync(body.Token);
                Nav.NavigateTo("/ben", true);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose() => Ui.OnChange -= StateHasChanged;
}
