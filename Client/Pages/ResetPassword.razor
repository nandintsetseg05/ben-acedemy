@page "/reset-password"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject UiCultureService Ui

<PageTitle>@Ui.T("reset_title")</PageTitle>

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4">@Ui.T("reset_title")</h1>
    <EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />
        <div class="mb-3">
            <label class="form-label">@Ui.T("email")</label>
            <InputText class="form-control" @bind-Value="_model.Email" readonly="@true" />
        </div>
        <div class="mb-3">
            <label class="form-label">@Ui.T("password")</label>
            <InputText type="password" class="form-control" @bind-Value="_model.NewPassword" />
        </div>
        <button class="btn btn-primary" type="submit" disabled="@_busy">@Ui.T("submit")</button>
    </EditForm>
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
    @if (_ok)
    {
        <div class="alert alert-success mt-3">Password updated. <a href="/login">@Ui.T("cta_login")</a></div>
    }
</div>

@code {
    private readonly ResetPasswordRequest _model = new();
    private bool _busy, _ok;
    private string? _error;

    protected override void OnInitialized()
    {
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query.TrimStart('?');
        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length != 2) continue;
            var key = Uri.UnescapeDataString(kv[0]);
            var val = Uri.UnescapeDataString(kv[1]);
            if (key.Equals("email", StringComparison.OrdinalIgnoreCase))
                _model.Email = val;
            if (key.Equals("token", StringComparison.OrdinalIgnoreCase))
                _model.Token = val;
        }
    }

    private async Task OnSubmitAsync()
    {
        _busy = true;
        _error = null;
        var client = HttpFactory.CreateClient("Api");
        var res = await client.PostAsJsonAsync("api/auth/reset-password", _model);
        if (!res.IsSuccessStatusCode)
        {
            _error = await res.Content.ReadAsStringAsync();
        }
        else
            _ok = true;
        _busy = false;
    }
}
