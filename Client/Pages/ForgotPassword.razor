@page "/forgot-password"
@inject IHttpClientFactory HttpFactory
@inject UiCultureService Ui

<PageTitle>@Ui.T("forgot_title")</PageTitle>

<div class="container py-5" style="max-width: 520px;">
    <h1 class="h3 mb-4">@Ui.T("forgot_title")</h1>
    <p class="text-muted small">We will email a reset link if the account exists. In development, check server logs for the link.</p>
    <EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />
        <div class="mb-3">
            <label class="form-label">@Ui.T("email")</label>
            <InputText class="form-control" @bind-Value="_model.Email" />
        </div>
        <button class="btn btn-primary" type="submit" disabled="@_busy">@Ui.T("submit")</button>
    </EditForm>
    @if (_done)
    {
        <div class="alert alert-info mt-3">If the account exists, instructions were sent.</div>
    }
    <p class="mt-3"><a href="/login">@Ui.T("cta_login")</a></p>
</div>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _busy, _done;

    private async Task OnSubmitAsync()
    {
        _busy = true;
        var client = HttpFactory.CreateClient("Api");
        await client.PostAsJsonAsync("api/auth/forgot-password", _model);
        _done = true;
        _busy = false;
    }
}
